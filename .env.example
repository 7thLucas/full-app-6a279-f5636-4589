_KEYSPACE=keyspace
_USER_ID=1234
MONGODB_URI=mongodb://localhost:27017/escapeops

# JWT Auth
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this
JWT_EXPIRES_IN=7d

# App URL
APP_URL=http://localhost:3000

# Admin seed — creates an admin user on first startup
SEED_ADMIN_ENABLE=true
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_EMAIL=admin@escapeops.com
SEED_ADMIN_PASSWORD=EscapeOps123!
